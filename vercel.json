{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_SITE_URL": {
      "description": "Public site URL",
      "required": true
    },
    "NEXT_PUBLIC_API_URL": {
      "description": "API base URL",
      "required": true
    },
    "NEXT_PUBLIC_API_VERSION": {
      "description": "API version",
      "required": false,
      "value": "v1"
    },
    "NEXT_PUBLIC_DEFAULT_LOCALE": {
      "description": "Default language locale",
      "required": false,
      "value": "en-US"
    },
    "NEXT_PUBLIC_SUPPORTED_LOCALES": {
      "description": "Comma-separated list of supported locales",
      "required": false,
      "value": "en-US,pt-BR,es-ES"
    },
    "NEXT_PUBLIC_ENABLE_ANALYTICS": {
      "description": "Enable analytics features",
      "required": false,
      "value": "false"
    },
    "NEXT_PUBLIC_ENABLE_PORTFOLIO": {
      "description": "Enable portfolio section",
      "required": false,
      "value": "true"
    },
    "NEXT_PUBLIC_GA_ID": {
      "description": "Google Analytics ID (optional)",
      "required": false
    },
    "NEXT_PUBLIC_HOTJAR_ID": {
      "description": "Hotjar ID (optional)",
      "required": false
    },
    "API_KEY_SECRET": {
      "description": "Secret API key for backend communication",
      "required": true
    },
    "JWT_SECRET": {
      "description": "JWT signing secret",
      "required": true
    },
    "ALLOWED_ORIGINS": {
      "description": "Comma-separated CORS allowed origins",
      "required": true
    },
    "EMAIL_SERVICE_PROVIDER": {
      "description": "Email service provider (sendgrid, etc)",
      "required": false
    },
    "EMAIL_API_KEY": {
      "description": "Email service API key",
      "required": false
    },
    "EMAIL_FROM": {
      "description": "Email sender address",
      "required": false
    },
    "EMAIL_CONTACT_TO": {
      "description": "Email recipient for contact form",
      "required": false
    },
    "GITHUB_TOKEN": {
      "description": "GitHub token for portfolio data (optional)",
      "required": false
    },
    "NODE_ENV": {
      "description": "Node environment",
      "required": true
    },
    "DEBUG": {
      "description": "Debug mode flag",
      "required": false,
      "value": "false"
    },
    "LOG_LEVEL": {
      "description": "Log level (error, warn, info, debug)",
      "required": false,
      "value": "info"
    }
  },
  "regions": ["sfo1"],
  "git": {
    "deploymentEnabled": true
  }
}
